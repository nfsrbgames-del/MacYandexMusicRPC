# ============================================================
# MacYandexMusicRPC — Настройки
# ============================================================
# Скопируй в .env: cp .env.example .env
# НЕ коммить .env! Он в .gitignore
# ============================================================

# Discord Application ID (дефолт — «Яндекс Музыку»)
CLIENT_ID=1269826362399522849

# Токен Яндекс Музыки — ЛУЧШЕ ЧЕРЕЗ МЕНЮ 🎵 → 🔑 Токен
# (хранится в macOS Keychain, безопасно)
# Но можно и тут:
YANDEX_TOKEN=

# Строгий поиск (true — точное совпадение, false — первый результат)
STRONG_FIND=true

# Интервал обновления (секунды)
UPDATE_INTERVAL=5
